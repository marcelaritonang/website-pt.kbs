# ===========================================
# KBS Website - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# JWT Secret - REQUIRED (generate a strong random string, min 32 chars)
# Example: openssl rand -base64 32
JWT_SECRET=

# Database (Vercel Postgres)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Backend URL for contact form
NEXT_PUBLIC_BACKEND_URL=https://backend-kbs-website.vercel.app

# Seed endpoint protection (only works in development)
SEED_SECRET=

# Node environment
NODE_ENV=development
